generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String                 @id @default(uuid())
  name                String                 @db.VarChar(255)
  email               String                 @unique @db.VarChar(255)
  password            String                 @db.VarChar(255)
  role                UserRole               @default(USER)
  plan                SubscriptionPlan       @default(FREE)
  planStatus          SubscriptionPlanStatus @default(NONE)
  planExpiresAt       DateTime?
  isActive            Boolean                @default(true)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  lastLogin           DateTime?
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  vehicles            Vehicle[]
  subscriptions       Subscription[]

  @@map("users")
}

enum SubscriptionPlan {
  FREE
  PREMIUM
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionPlanStatus {
  NONE
  PENDING
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  REJECTED
}

/**
 * FREE + NONE = usuário gratuito
 * PREMIUM + PENDING = iniciou assinatura, mas ainda não pagou
 * PREMIUM + ACTIVE = assinante ativo
 * PREMIUM + CANCELLED = cancelou
 * PREMIUM + EXPIRED = assinatura vencida
 * PREMIUM + REJECTED = pagamento recusado
 */

model Subscription {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   SubscriptionPlan       @default(PREMIUM)
  status SubscriptionPlanStatus @default(PENDING)

  // Mercado Pago preapproval/subscription identifiers and raw provider status.
  mercadoPagoPreapprovalId String? @unique @db.VarChar(255)
  mercadoPagoPayerId       String? @db.VarChar(255)
  mercadoPagoStatus        String? @db.VarChar(50)
  mercadoPagoCollectorId   String? @db.VarChar(255)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("BRL") @db.VarChar(10)

  reason            String? @db.VarChar(255)
  externalReference String? @db.VarChar(255)

  startedAt     DateTime?
  nextPaymentAt DateTime?
  lastPaymentAt DateTime?
  cancelledAt   DateTime?
  expiresAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metadata Json? @db.Json

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique @db.VarChar(255)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique @db.VarChar(255)
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Vehicle {
  id String @id @default(uuid())

  // Ownership relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Vehicle identity
  plate   String? @db.VarChar(10)
  brand   String? @db.VarChar(100)
  model   String? @db.VarChar(100)

  yearManufacture Int?
  yearModel       Int?

  color        String?           @db.VarChar(50)
  fuelType     FuelType?
  transmission TransmissionType?
  type         VehicleType       @default(CAR)

  mileage Int?

  images VehicleImage[]

  // Market values
  fipeCode    String?  @db.VarChar(20)
  fipeValue   Decimal? @db.Decimal(12, 2)
  marketValue Decimal? @db.Decimal(12, 2)

  evaluation VehicleEvaluation?

  // Auction details
  auctioneer  String?      @db.VarChar(150)
  auctionType AuctionType?

  sourceUrl String? @db.Text

  eventDate DateTime?

  city  String? @db.VarChar(100)
  state String? @db.VarChar(2)

  yardAddress String? @db.Text

  auctionInitialBid Decimal? @db.Decimal(12, 2)
  auctionCurrentBid Decimal? @db.Decimal(12, 2)

  purchasePrice Decimal?  @db.Decimal(12, 2)
  purchasedAt   DateTime?
  soldPrice     Decimal?  @db.Decimal(12, 2)
  soldAt        DateTime?

  damageType VehicleDamageType @default(NONE)

  // Workflow state
  status VehicleStatus @default(ANALYZING)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("vehicles")
}

enum FuelType {
  GASOLINE
  ETHANOL
  FLEX
  DIESEL
  ELECTRIC
  HYBRID
  GNV
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  CVT
  AUTOMATED
}

enum AuctionType {
  JUDICIAL
  EXTRAJUDICIAL
  BANK
  INSURANCE
  DEALERSHIP
  OTHER
}

enum VehicleStatus {
  ANALYZING
  REJECTED
  PURCHASED
  SOLD
}

enum VehicleDamageType {
  NONE
  LOW_DAMAGE
  MEDIUM_DAMAGE
  HIGH_DAMAGE
  FLOOD
  OTHER
}

enum VehicleType {
  CAR
  MOTORCYCLE
}

model VehicleImage {
  id String @id @default(uuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  url      String @db.Text
  filename String @db.VarChar(255)
  mimetype String @db.VarChar(100)
  size     Int

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@map("vehicle_images")
}

model VehicleEvaluation {
  id String @id @default(uuid())

  vehicleId String  @unique
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // Margin inputs
  desiredProfitMarginPercent Decimal? @default(15.00) @db.Decimal(5, 2)
  safetyMarginPercent        Decimal? @default(5.00) @db.Decimal(5, 2)

  // Calculated financial results
  maxRecommendedBid  Decimal? @db.Decimal(12, 2)
  estimatedFinalCost Decimal? @db.Decimal(12, 2)
  estimatedProfit    Decimal? @db.Decimal(12, 2)

  // Evaluation classification
  riskLevel      EvaluationRiskLevel?
  recommendation EvaluationRecommendation?

  isComplete       Boolean   @default(false)
  lastCalculatedAt DateTime?

  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  evaluationExpenses       EvaluationExpense[]
  evaluationChecklistItems EvaluationChecklistItem[]

  @@index([vehicleId])
  @@index([riskLevel])
  @@index([recommendation])
  @@map("vehicle_evaluations")
}

enum EvaluationRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum EvaluationRecommendation {
  RECOMMENDED
  CAUTION
  NOT_RECOMMENDED
}

model EvaluationExpense {
  id String @id @default(uuid())

  evaluationId String
  evaluation   VehicleEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  category ExpenseCategory
  source   ExpenseSource

  name   String
  amount Decimal @db.Decimal(12, 2)

  isRequired Boolean @default(false)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([evaluationId, name, source])
  @@index([evaluationId])
  @@index([category])
  @@map("evaluation_expenses")
}

enum ExpenseCategory {
  DOCUMENTATION
  REPAIR
  AUCTION_FEE
  TRANSPORT
  INSPECTION
  DEBT
  REGULARIZATION
  PREPARATION_SALE
  OTHER
}

enum ExpenseSource {
  USER
  SYSTEM
  CHECKLIST
  AUCTION_RULE
  DOCUMENTATION_RULE
}

model ChecklistTemplate {
  id String @id @default(uuid())

  name        String      @db.VarChar(255)
  vehicleType VehicleType

  isActive Boolean @default(true)

  items ChecklistTemplateItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vehicleType, name])
  @@index([vehicleType, isActive])
  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id String @id @default(uuid())

  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  category String  @db.VarChar(100)
  name     String  @db.VarChar(255)
  question String? @db.VarChar(255)

  defaultEstimatedCost Decimal?          @db.Decimal(12, 2)
  severity             ChecklistSeverity @default(MEDIUM)

  requiresQuantity Boolean @default(false)
  isRequired       Boolean @default(false)
  isPremiumOnly    Boolean @default(false)

  order Int @default(0)

  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  evaluationChecklistItems EvaluationChecklistItem[]

  @@unique([templateId, name])
  @@index([templateId, order])
  @@map("checklist_template_items")
}

model EvaluationChecklistItem {
  id String @id @default(uuid())

  evaluationId String
  evaluation   VehicleEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  templateItemId String?
  templateItem   ChecklistTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)

  category String  @db.VarChar(100)
  name     String  @db.VarChar(255)
  question String? @db.VarChar(255)

  severity ChecklistSeverity @default(MEDIUM)

  requiresQuantity Boolean @default(false)
  isRequired       Boolean @default(false)

  order Int @default(0)

  status ChecklistItemStatus @default(NOT_CHECKED)

  quantity Int @default(1)

  estimatedUnitCost  Decimal? @db.Decimal(12, 2)
  estimatedTotalCost Decimal? @db.Decimal(12, 2)

  notes String? @db.Text

  answeredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([evaluationId, templateItemId])
  @@index([evaluationId])
  @@index([templateItemId])
  @@index([evaluationId, status])
  @@index([evaluationId, order])
  @@map("evaluation_checklist_items")
}

enum ChecklistSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ChecklistItemStatus {
  NOT_CHECKED
  OK
  ATTENTION
  NEEDS_REPAIR
  NOT_APPLICABLE
}
