# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# Frontend public URL used in CORS and password/subscription redirects.
APP_FRONTEND_URL=http://localhost:4200

# Optional. Use comma-separated origins when the API should accept more than one
# frontend URL, for example: http://localhost:4200,https://app.example.com
CORS_ORIGIN=http://localhost:4200

# Enables Swagger at /api when true.
# Keep false in production. The API refuses to boot with
# NODE_ENV=production and SWAGGER_ENABLED=true.
SWAGGER_ENABLED=true

# Optional shared storage for distributed rate limiting in production.
# Leave empty/unset in local development to use in-memory throttling.
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# PostgreSQL / Docker Compose
# -----------------------------------------------------------------------------
POSTGRES_USER=lance_certo
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lance_certo
POSTGRES_PORT=5432

# Prisma database connection string.
DATABASE_URL=postgresql://lance_certo:change-me@localhost:5432/lance_certo?schema=public

# Direct PostgreSQL URL used by Prisma CLI commands such as generate/migrate.
# In Supabase, use the direct/session pooler connection for migrations.
DIRECT_URL=postgresql://lance_certo:change-me@localhost:5432/lance_certo?schema=public

# Optional seed passwords. Required only when running the seed outside
# development/test.
ADMIN_SEED_PASSWORD=change-me-admin-seed-password
USER_SEED_PASSWORD=change-me-user-seed-password

# -----------------------------------------------------------------------------
# Authentication / JWT
# -----------------------------------------------------------------------------
# Use a long random value in production.
JWT_SECRET=change-me-generate-a-long-random-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_DAYS=7

# Refresh token cookie settings.
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Email / SMTP
# -----------------------------------------------------------------------------
# Used to send password reset emails. In development, the API logs the reset
# link only when SMTP is not configured. In production, configure SMTP.
EMAIL_FROM="Lance Certo <no-reply@example.com>"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password

# -----------------------------------------------------------------------------
# Mercado Pago
# -----------------------------------------------------------------------------
# Mercado Pago access token. Use TEST-* in sandbox and APP_USR-* in production.
MERCADO_PAGO_ACCESS_TOKEN=TEST-your-mercado-pago-access-token

# Preapproval plan ID created in Mercado Pago for the Premium subscription.
MERCADO_PAGO_PREMIUM_PLAN_ID=your-mercado-pago-preapproval-plan-id

# Secret configured in Mercado Pago webhook signature settings.
MERCADO_PAGO_WEBHOOK_SECRET=change-me-mercado-pago-webhook-secret

# Public URL registered in Mercado Pago notifications.
# In local development, expose the API with ngrok/cloudflared and use HTTPS.
MERCADO_PAGO_WEBHOOK_URL=https://your-public-url.com/subscription/webhook/mercado-pago

# -----------------------------------------------------------------------------
# FIPE
# -----------------------------------------------------------------------------
FIPE_BASE_URL=https://fipe.parallelum.com.br/api/v2
FIPE_TOKEN=
FIPE_TIMEOUT_MS=5000
